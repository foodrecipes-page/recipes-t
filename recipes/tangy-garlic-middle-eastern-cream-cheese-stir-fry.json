{
  "title": "Tangy Garlic Middle Eastern Cream Cheese Stir-fry",
  "description": "A tangy and creamy mid-day dish that pairs perfectly with grilled meats or vegetables. Halal-friendly and midnight-craving.",
  "cuisine": "Middle Eastern",
  "diet": [
    "halal"
  ],
