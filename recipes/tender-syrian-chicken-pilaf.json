  "instructions": [
    "Heat the olive oil in a large saucepan over medium heat.",
    "Add the chopped onion, carrot, and celery, and cook until the vegetables are tender, about 5 minutes.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the cumin, coriander, paprika, salt, and black pepper, and stir to combine.",
    "Add the brown rice and stir to coat the rice with the spice mixture.",
    "Add the chicken broth and bring the mixture to a boil.",
    "Reduce the heat to low, cover the saucepan, and simmer for 25 minutes.",
    "Add the chopped parsley and stir to combine.",
    "Add the chicken breast to the saucepan and continue to simmer for 10-15 minutes, or until the chicken is cooked through and the rice is tender.",
    "Remove the saucepan from the heat and let it rest for 5 minutes before serving."
