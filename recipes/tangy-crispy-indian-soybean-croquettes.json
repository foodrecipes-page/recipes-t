      "amount": "2 tsp"
    },
    {
      "name": "green chili, finely chopped",
      "amount": "1"
    },
    {
      "name": "fresh cilantro, chopped",
      "amount": "\u00bc cup"
    },
    {
      "name": "tamarind paste",
      "amount": "1 tsp"
    },
    {
      "name": "lemon juice",
      "amount": "2 tbsp"
    },
    {
