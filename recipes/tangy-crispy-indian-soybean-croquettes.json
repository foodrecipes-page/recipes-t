      "amount": "1 tsp"
    },
    {
      "name": "salt & pepper",
      "amount": "pinch each"
    },
    {
      "name": "chickpea flour batter",
      "amount": "2 tbsp chickpea flour + 2 tbsp water"
    },
    {
      "name": "breadcrumb\u2011cornflour coating",
      "amount": "\u00bd cup breadcrumbs + 1 tbsp cornflour"
    },
    {
      "name": "oil for deep frying",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "In a large bowl, combine the cooked soybeans, chopped onion, green chili, cilantro, tamarind paste, lemon juice, spice blend, and salt & pepper.",
    "Add garlic & ginger paste and mix thoroughly.",
    "Fold the chickpea flour batter into the mixture until it holds together.",
    "Shape the mixture into small oval patties, about 3 inches long.",
    "Roll each patty in the breadcrumb\u2011cornflour coating until fully covered.",
    "Heat oil in a deep pan to 180\u00b0C (356\u00b0F). Fry the croquettes in batches, turning once, until golden and crisp, about 3\u20134 minutes.",
    "Transfer fried croquettes to paper towels to drain excess oil.",
    "Serve hot with a chilled vegan coriander\u2011lime chutney or your favorite dairy\u2011free dip."
  ],
