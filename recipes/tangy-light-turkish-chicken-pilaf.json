{
  "title": "Tangy Light Turkish Chicken Pilaf",
  "description": "A flavorful and healthy Turkish dish featuring chicken, currants, and a hint of lemon, perfect for those looking for a diabetic-friendly meal option.",
  "cuisine": "Turkish",
  "diet": [
    "diabetic-friendly",
    "gluten-free"
