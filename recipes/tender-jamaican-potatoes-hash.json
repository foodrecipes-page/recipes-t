  "ingredients": [
    {
      "name": "1 1/2 pounds baby new potatoes",
      "amount": "peeled and cut into 1/2-inch cubes"
    },
    {
      "name": "1/4 cup nuka-pickle",
      "amount": "chopped"
    },
    {
      "name": "2 tablespoons vegetable oil",
      "amount": ""
    },
    {
      "name": "1 onion",
      "amount": "chopped"
    },
    {
      "name": "2 cloves garlic",
      "amount": "minced"
    },
    {
      "name": "1 teaspoon Jamaican curry powder",
      "amount": ""
    },
    {
      "name": "1/2 teaspoon salt",
      "amount": ""
    },
    {
      "name": "1/4 teaspoon black pepper",
      "amount": ""
    }
  ],
  "instructions": [
    "Heat the oil in a large skillet over medium-high heat.",
    "Add the onion and garlic and cook until softened, about 3 minutes.",
    "Add the potatoes and cook for 5 minutes, stirring occasionally.",
    "Add the nuka-pickle, curry powder, salt, and pepper, and stir to combine.",
    "Continue cooking for an additional 5-7 minutes, or until the potatoes are tender and crispy.",
    "Serve hot."
  ],
