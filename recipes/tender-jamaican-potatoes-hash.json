{
  "title": "Tender Jamaican Potatoes Hash",
  "description": "A crispy and flavorful side dish featuring baby new potatoes, nuka-pickle, and a hint of Caribbean spices. Perfect for a quick weeknight dinner.",
  "cuisine": "Jamaican",
  "diet": [
    "low-carb",
    "gluten-free"
  ],
