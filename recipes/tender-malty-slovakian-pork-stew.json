{
  "title": "Tender Malty Slovakian Pork Stew",
  "description": "A hearty one-pot Slovakian dish featuring pork, malty flavors, and Thai sweet basil, perfect for a cold evening. This sugar-free-friendly stew is made with salt-baked ingredients for added depth.",
  "cuisine": "Slovakian",
  "diet": [
    "sugar-free",
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "pork shoulder",
      "amount": "2 pounds",
      "notes": "cut into 1-inch cubes"
    },
    {
      "name": "Thai sweet basil",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "malt extract",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and sliced"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "peeled and cubed"
    },
    {
      "name": "chicken broth",
      "amount": "4 cups"
    }
  ],
  "instructions": [
    "Heat a large Dutch oven over medium-high heat.",
    "Add the pork cubes and cook until browned on all sides, about 5 minutes.",
    "Add the chopped Thai sweet basil and cook for 1 minute.",
    "Add the malt extract, salt, and black pepper, and stir to combine.",
    "Add the sliced carrots and cubed potatoes, and stir to combine.",
    "Pour in the chicken broth and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 2 hours.",
    "Serve hot, garnished with additional Thai sweet basil if desired."
  ],
