{
  "title": "Tasty Peppery Ukrainian Rice Bake",
  "description": "A hearty, low-fat Ukrainian dish featuring rice, baked to perfection with a peppery flavor, this recipe is perfect for a weeknight dinner",
  "cuisine": "Ukrainian",
