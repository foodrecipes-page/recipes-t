  "ingredients": [
    {
      "name": "uncooked white rice",
      "amount": "1 1/2 cups",
      "notes": "rinsed and drained"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "ground black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "low-fat sour cream",
      "amount": "1/2 cup"
    },
    {
      "name": "shredded cheese",
      "amount": "1/2 cup",
      "notes": "low-fat"
    }
  ],
  "instructions": [
    "Preheat oven to 375 degrees Fahrenheit.",
    "In a large saucepan, heat the chicken broth over medium heat.",
    "Add the rice to the saucepan and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 18 minutes.",
    "While the rice is cooking, heat a small skillet over medium heat and saute the onion and garlic until softened.",
    "In a large bowl, combine the cooked rice, sauteed onion and garlic, paprika, salt, and pepper.",
    "Stir in the low-fat sour cream and shredded cheese until well combined.",
    "Transfer the rice mixture to a 9x13 inch baking dish and bake for 20 minutes.",
    "Remove from the oven and let cool for a few minutes before serving."
  ],
