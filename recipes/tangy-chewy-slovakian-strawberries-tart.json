{
  "title": "Tangy Chewy Slovakian Strawberries Tart",
  "description": "A plant-based friendly, date-night dessert featuring tangy strawberries, a crumbly Slovakian-inspired crust, and a chewy filling.",
  "cuisine": "Slovakian",
  "diet": [
    "vegetarian",
    "vegan"
