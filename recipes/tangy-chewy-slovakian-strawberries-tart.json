      "amount": "3 cups, hulled and sliced"
    },
    {
      "name": "Almond flour",
      "amount": "1 1/2 cups"
    },
    {
      "name": "Coconut sugar",
      "amount": "1/2 cup"
    },
    {
      "name": "Unsalted coconut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "Maple syrup",
      "amount": "2 tbsp"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tbsp"
    },
    {
      "name": "Vanilla extract",
      "amount": "1 tsp"
    },
    {
      "name": "Cornstarch",
      "amount": "2 tbsp"
    },
    {
      "name": "Water",
      "amount": "2 tbsp"
    },
    {
      "name": "Confectioners' sugar",
      "amount": "1/4 cup"
    },
    {
      "name": "Slushed raspberries",
      "amount": "1/4 cup"
    },
    {
      "name": "Fresh mint leaves",
      "amount": "handful"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "In a medium bowl, whisk together almond flour, coconut sugar, and cornstarch.",
    "Add the coconut oil and maple syrup to the bowl. Mix until crumbly.",
    "Press the mixture into the bottom and up the sides of a 9-inch tart pan.",
    "Bake for 18-20 minutes or until lightly golden.",
    "In a blender or food processor, puree the strawberries, lemon juice, and vanilla extract until smooth.",
    "In a small bowl, mix together the cornstarch and water until smooth.",
    "Add the slushed raspberries to the bowl and puree again.",
    "Pour the strawberry mixture over the baked tart crust.",
    "Top with the confectioners' sugar and slushed raspberries.",
    "Garnish with fresh mint leaves.",
    "Chill in the refrigerator for at least 2 hours before serving."
  ],
