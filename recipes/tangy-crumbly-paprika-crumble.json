{
  "title": "Tangy Crumbly Paprika Crumble",
  "description": "A quick-fix Canadian dish featuring tangy paprika crumble as a side or topping for meals.",
  "cuisine": "Canadian",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
