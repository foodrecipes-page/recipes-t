      "name": "paprika",
      "amount": "1 tsp"
    },
    {
      "name": "dijon mustard",
      "amount": "1 tbsp"
    },
    {
      "name": "mayonnaise",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "a pinch"
    },
    {
      "name": "black pepper",
      "amount": "a pinch"
    },
    {
      "name": "unsalted butter",
      "amount": "2 tbsp"
    },
    {
      "name": "all-purpose flour",
      "amount": "1/4 cup"
    },
    {
      "name": "cooking spray",
      "notes": "for greasing pan if needed"
    }
  ],
  "instructions": [
    "Preheat oven to 350\u00b0F (175\u00b0C).",
    "Mix dijon mustard, mayonnaise, paprika, salt, and pepper in a bowl.",
    "Gradually add flour while stirring until mixture becomes crumbly but holds together.",
    "Add butter cubes. Stir until the mixture is evenly coated with oil from the butter.",
    "Spray an oven-safe dish lightly with cooking spray if needed. Spread the paprika crumble evenly over it.",
    "Bake for 10-12 minutes or until golden brown and crispy on top. Let cool slightly before serving."
  ],
