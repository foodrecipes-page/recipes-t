{
  "title": "Tender Smoke Greek Citrus Stir-fry",
  "description": "A citrusy and tender one-pot greek dish featuring white flour, smoke flavoring, and dairy-free-friendly elements.",
  "cuisine": "Grecian",
  "diet": [
    "dairy-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "white flour",
      "amount": "1 cup"
    },
    {
      "name": "smoke flavoring spray",
      "amount": "2-3 sprays"
    },
    {
      "name": "citrus zest (e.g. orange, lemon)",
      "amount": "1/4 tsp each"
    },
    {
      "name": "dairy-free yogurt",
      "amount": "1/2 cup"
    },
    {
      "name": "dairy-free cheese shreds (optional for topping)",
      "amount": "3 tbsp"
    },
    {
      "name": "garlic cloves",
      "amount": "2-3, minced"
    },
    {
      "name": "onion, finely chopped",
      "amount": "1"
    }
  ],
  "instructions": [
    "Preheat oven to 400\u00b0F (200\u00b0C).",
    "In a large bowl, mix flour and smoke flavoring. Stir in garlic and onion.",
    "Fold in the citrus zest into the flour mixture.",
    "Transfer the doughy mixture onto a baking sheet lined with parchment paper.",
    "Bake for 15 minutes or until golden brown on top.",
    "Remove from oven and sprinkle with dairy-free yogurt evenly.",
    "If using, top with cheese shreds before returning to the oven to melt for an additional 2-3 minutes.",
    "Serve hot as a side dish or main meal."
  ],
