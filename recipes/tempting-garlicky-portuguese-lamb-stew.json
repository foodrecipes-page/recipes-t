      "amount": "6 cloves",
      "notes": "minced"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "carrots",
      "amount": "2 large",
      "notes": "chopped"
    },
    {
      "name": "celery",
      "amount": "2 stalks",
      "notes": "chopped"
    },
    {
      "name": "coriander leaves",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "red wine",
      "amount": "1 cup"
    },
    {
      "name": "beef broth",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium-high heat.",
    "Add the lamb cubes and cook until browned on all sides, about 5 minutes.",
    "Add the garlic, onion, carrots, and celery, and cook until the vegetables are tender, about 10 minutes.",
    "Add the coriander leaves, tomato paste, red wine, and beef broth, and stir to combine.",
    "Bring the stew to a boil, then reduce the heat to low and simmer, covered, for 1.5 hours.",
    "Season the stew with salt and pepper to taste.",
    "Serve the stew hot, garnished with additional coriander leaves if desired."
  ],
