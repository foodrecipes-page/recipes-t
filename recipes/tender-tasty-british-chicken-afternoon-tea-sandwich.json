{
  "title": "Tender Tasty British Chicken Afternoon Tea Sandwich",
  "description": "A fermented and snappy British dish featuring Thai holy basil krapao, perfect for a sick day, with an ayurvedic tamasic friendly twist, served as an afternoon tea sandwich.",
  "cuisine": "British",
  "diet": [
    "gluten-free",
    "soy-free"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "boneless and skinless"
    },
    {
      "name": "Thai holy basil",
      "amount": "1/4 cup",
      "notes": "fresh leaves"
    },
    {
      "name": "krapao sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "plain yogurt",
      "amount": "1/2 cup"
    },
    {
      "name": "lemon juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "honey",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "whole wheat bread",
      "amount": "1 loaf",
      "notes": "fermented for 24 hours"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a blender, combine chicken breast, Thai holy basil, krapao sauce, plain yogurt, lemon juice, honey, salt, and black pepper, and blend until smooth.",
    "Pour the mixture into a baking dish and bake for 20 minutes.",
    "Remove the dish from the oven and let it rest for 10 minutes.",
    "Slice the whole wheat bread into thin pieces and toast until crispy.",
    "Spread a layer of the chicken mixture onto each bread slice.",
    "Top with additional Thai holy basil leaves and serve.",
    "Let the sandwiches rest for 5 minutes before serving to allow the flavors to meld.",
    "Serve immediately and enjoy."
  ],
