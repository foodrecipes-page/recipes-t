    {
      "name": "shio cure",
      "amount": "1/4 cup",
      "notes": "or salt cure"
    },
    {
      "name": "vegetable oil",
      "amount": "1/2 cup"
    },
    {
      "name": "takoyaki sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "bonito flakes",
      "amount": "1/4 cup"
    },
    {
      "name": "green onion",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "In a large bowl, whisk together flour and water until smooth.",
    "Add shio cure and mix well.",
    "Heat the vegetable oil in a deep frying pan to 350 degrees Fahrenheit.",
    "Using a takoyaki pan, pour the batter and top with sliced bananas.",
    "Cook for 3-4 minutes on each side, until golden brown.",
    "Remove from heat and brush with takoyaki sauce.",
    "Sprinkle bonito flakes and chopped green onion on top.",
    "Serve immediately and enjoy."
  ],
