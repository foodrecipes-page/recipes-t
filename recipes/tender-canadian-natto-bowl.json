{
  "title": "Tender Canadian Natto Bowl",
  "description": "A herbal and velvety solo dinner dish featuring natto, cooked in a clay pot and served in a dolsot stone bowl, suitable for ovo-vegetarian diets.",
  "cuisine": "Canadian",
  "diet": [
    "ovo-vegetarian"
  ],
