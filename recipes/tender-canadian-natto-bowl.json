    {
      "name": "natto",
      "amount": "1 cup",
      "notes": "Japanese fermented soybeans"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "mushrooms",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "egg",
      "amount": "1 large",
      "notes": "poached"
    },
    {
      "name": "Canadian cheddar cheese",
      "amount": "1/4 cup",
      "notes": "shredded"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a clay pot, heat the olive oil over medium heat.",
    "Add the sliced onion and cook until it is translucent.",
    "Add the sliced mushrooms and cook until they are tender.",
    "Add the minced garlic and cook for one minute.",
    "Add the natto, thyme, salt, and black pepper, and stir to combine.",
    "Transfer the clay pot to the preheated oven and bake for 15 minutes.",
    "While the natto mixture is baking, poach the egg in a separate pot of boiling water.",
    "To assemble the dish, place the cooked natto mixture in a dolsot stone bowl, top with the poached egg and shredded Canadian cheddar cheese.",
    "Serve immediately and enjoy."
  ],
