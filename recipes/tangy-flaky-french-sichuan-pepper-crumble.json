      "name": "2 ripe bananas",
      "amount": "1 per serving"
    },
    {
      "name": "2 tablespoons honey",
      "amount": "1 tablespoon per serving"
    },
    {
      "name": "30 grams all-purpose flour",
      "amount": "5 grams per serving"
    },
    {
      "name": "40 grams almond flour",
      "amount": "6 grams per serving"
    },
    {
      "name": "8 grams fine sea salt",
      "amount": "1 gram per serving"
    },
    {
      "name": "2 tablespoons vegetable oil",
      "amount": "0.33 tablespoons per serving"
    },
    {
      "name": "2 teaspoons granulated sugar",
      "amount": "0.5 teaspoon per serving"
    },
    {
      "name": "6 fresh cilantro leaves",
      "amount": "1 leaf per serving"
    }
  ],
  "instructions": [
    "Preheat oven to 180°C (350°F).",
    "Marinate sliced bananas in honey and a pinch of salt for at least 4 hours.",
    "Blend banana mixture with flours, oil, sugar, and finely chopped cilantro until a smooth spreadable consistency is achieved.",
    "Spray baking sheets with cooking spray or line with parchment paper.",
    "Spoon out spoonfuls onto the prepared sheet pans to form crumbles. Bake for 15 minutes until golden brown on top.",
    "Serve warm, garnished with fresh cilantro leaves."
