  "ingredients": [
    {
      "name": "Thai sweet basil (Horapa)",
      "amount": "2 cups",
      "notes": "fresh leaves only"
    },
    {
      "name": "Egyptian coriander",
      "amount": "2 tsp",
      "notes": "ground powder"
    },
    {
      "name": "Turmeric",
      "amount": "1 tsp",
      "notes": "ground powder"
    },
    {
      "name": "Cumin",
      "amount": "1 tsp",
      "notes": "ground powder"
    },
    {
      "name": "Ghee",
      "amount": "2 tbsp",
      "notes": "clarified butter"
    },
    {
      "name": "Coconut oil",
      "amount": "1 tbsp",
      "notes": "for frying"
    },
    {
      "name": "Onions",
      "amount": "2 medium",
      "notes": "chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "Carrots",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "Potatoes",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "Dried apricots",
      "amount": "1 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the ghee in a clay or ceramic tagine over medium heat. Add the cumin, coriander, and turmeric, and stir for 1 minute.",
    "Add the onions and saut\b3 until they are caramelized, about 8 minutes.",
    "Add the garlic and saut\b3 for 1 minute.",
    "Add the carrots and potatoes, and stir to coat with the spice mixture.",
    "Add the chopped apricots, and stir to combine.",
    "Add the Thai basil leaves, and stir to combine.",
    "Pour in enough water to cover the ingredients, and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 20 minutes, or until the potatoes are tender.",
    "Stir in the coconut oil, and serve hot."
  ],
