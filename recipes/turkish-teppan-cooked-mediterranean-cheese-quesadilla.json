    },
    {
      "name": "1 cup of feta cheese, crumbled",
      "amount": "1"
    },
    {
      "name": "1 cup of grated mozzarella cheese",
      "amount": "1"
    },
    {
      "name": "1/2 cup of chopped fresh parsley",
      "amount": "1"
    },
    {
      "name": "1/4 cup of chopped fresh dill",
      "amount": "1"
    },
    {
      "name": "2 cloves of garlic, minced",
