{
  "title": "Tangy Irish Graham Cracker Crumbs Scones",
  "description": "Moist and tangy Irish scones featuring graham cracker crumbs, perfect for a sick-day treat",
  "cuisine": "Irish",
  "diet": [
    "gluten-free",
    "vegan"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "1 1/2 cups all-purpose flour",
      "amount": "12.75 oz"
    },
    {
      "name": "1/4 cup graham cracker crumbs",
      "amount": "2.75 oz"
    },
    {
      "name": "1/2 cup coconut milk",
      "amount": "4 oz"
    },
    {
      "name": "1/4 cup aquafaba",
      "amount": "2 oz"
    },
    {
      "name": "1 tsp baking powder",
      "notes": "gluten-free"
    },
    {
      "name": "1/2 tsp salt",
      "notes": "anti-inflammatory"
    },
    {
      "name": "1 tbsp apple cider vinegar",
      "notes": "tangy flavor"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "Line a baking sheet with parchment paper.",
    "In a large bowl, whisk together flour, graham cracker crumbs, baking powder, and salt.",
    "In a separate bowl, whisk together coconut milk, aquafaba, and apple cider vinegar.",
    "Pour wet ingredients into dry ingredients and stir until combined.",
    "Drop by tablespoonfuls onto prepared baking sheet.",
    "Bake for 18 minutes or until lightly golden brown.",
    "Remove from oven and let cool on wire rack for 5 minutes."
  ],
