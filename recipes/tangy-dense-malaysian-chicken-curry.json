      "name": "boneless chicken breast",
      "amount": "1 1/2 pounds",
      "notes": "cut into bite-sized pieces"
    },
    {
      "name": "mascarpone cheese",
      "amount": "1/2 cup"
    },
    {
      "name": "bhuna spice mix",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "tomato puree",
      "amount": "1 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a large pan over medium heat",
    "Add the chopped onion and cook until it is lightly browned",
    "Add the minced garlic and cook for 1 minute",
    "Add the bhuna spice mix and cook for 1 minute",
    "Add the chicken and cook until it is browned on all sides",
    "Add the tomato puree, salt, and black pepper, and stir to combine",
    "Reduce the heat to low and simmer, covered, for 20 minutes",
    "Stir in the mascarpone cheese until it is fully incorporated",
    "Simmer, uncovered, for an additional 5 minutes",
    "Garnish with chopped cilantro and serve over rice or with naan bread"
  ],
