      "amount": "1 medium",
      "notes": "peeled and diced"
    },
    {
      "name": "salt and pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pot over medium heat.",
    "Add the minced garlic and grated ginger, sauté for 1 minute until fragrant.",
    "Pour in the vegetable broth and bring to a gentle boil.",
    "Add the diced carrot and cook for 2 minutes.",
    "Stir in the chopped asparagus pieces and simmer for 8‑10 minutes until tender.",
    "Add the lemon juice, salt, and pepper, and adjust seasoning as needed.",
    "Remove from heat, then stir in the chopped parsley.",
    "Serve hot, garnished with extra parsley if desired."
