      "amount": "4 cups (1 liter)",
      "notes": "warm before adding"
    },
    {
      "name": "fresh lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "extra‑virgin olive oil",
      "amount": "1 tablespoon"
    },
