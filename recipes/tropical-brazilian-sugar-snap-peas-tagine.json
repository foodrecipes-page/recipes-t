      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat the coconut oil in the tajine clay vessel over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and grated ginger and cook for an additional 1 minute.",
    "Add the cumin, coriander, salt, and black pepper, and stir to combine.",
    "Add the sugar snap peas and stir to coat with the spice mixture.",
    "Pour in the lime juice and bring the mixture to a simmer.",
    "Reduce the heat to low and cook, covered, for 10 minutes.",
    "Serve the sugar snap peas hot, garnished with fresh herbs if desired."
  ],
