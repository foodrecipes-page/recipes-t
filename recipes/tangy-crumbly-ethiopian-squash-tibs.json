  "ingredients": [
    {
      "name": "2 medium butternut squash",
      "amount": "1 pound",
      "notes": "peeled and cubed"
    },
    {
      "name": "1/4 cup Ethiopian berbere spice mix",
      "amount": "2 tablespoons",
      "notes": "store-bought or homemade"
    },
    {
      "name": "2 tablespoons vegetable oil",
      "amount": "1 tablespoon",
      "notes": "for sautéing"
    },
    {
      "name": "1 small red onion",
      "amount": "1/2 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "1/4 cup chopped fresh cilantro",
      "amount": "2 tablespoons",
      "notes": "for garnish"
    },
    {
      "name": "1/4 cup chopped scallions",
      "amount": "2 tablespoons",
      "notes": "for garnish"
    },
    {
      "name": "1/4 cup pickled carrots",
      "amount": "1/2 cup",
      "notes": "store-bought or homemade"
    },
    {
      "name": "2 tablespoons apple cider vinegar",
      "amount": "1 tablespoon",
      "notes": "for tanginess"
    },
    {
      "name": "1 teaspoon maple syrup",
      "amount": "1/2 teaspoon",
      "notes": "for sweetness"
    },
    {
      "name": "1/4 cup nutritional yeast",
      "amount": "2 tablespoons",
      "notes": "for cheesy flavor"
    },
    {
      "name": "1/4 cup crumbled vegan feta cheese",
      "amount": "1/2 cup",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Preheat the oven to 400°F (200°C).",
    "Toss the squash with 1 tablespoon of oil, berbere spice mix, and salt. Roast for 30-40 minutes or until tender.",
    "In a pan, heat 1 tablespoon of oil over medium heat. Add the onion and cook until translucent.",
    "Add the roasted squash to the pan and stir to combine with the onion.",
    "In a small bowl, mix together the apple cider vinegar, maple syrup, and nutritional yeast. Pour the mixture over the squash and onion.",
    "Stir to combine and cook for an additional 2-3 minutes.",
    "Garnish with chopped cilantro, scallions, and pickled carrots.",
    "Serve hot, topped with crumbled vegan feta cheese if desired."
  ],
