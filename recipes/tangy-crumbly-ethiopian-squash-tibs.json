{
  "title": "Tangy Crumbly Ethiopian Squash Tibs",
  "description": "A flavorful and spicy Ethiopian dish made with roasted squash, pickled vegetables, and a crunchy topping.",
  "cuisine": "Ethiopian",
  "diet": [
    "vegan",
    "vegetarian",
