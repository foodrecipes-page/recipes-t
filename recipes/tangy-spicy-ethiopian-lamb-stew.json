      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "berbere spice",
      "amount": "2 tablespoons"
    },
    {
      "name": "lacquer-glaze",
      "amount": "1/4 cup"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Heat oil in a large pot over medium heat.",
    "Add the onion and cook until softened, about 5 minutes.",
    "Add the garlic and ginger and cook for 1 minute.",
    "Add the lamb and cook until browned, about 5 minutes.",
    "Add the green chilli, berbere spice, and lacquer-glaze, and cook for 1 minute.",
    "Add the chicken broth and tomato paste, and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 1 1/2 hours.",
    "Season with salt and pepper to taste.",
    "Serve hot over injera bread."
  ],
