      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "green chilli",
      "amount": "2",
      "notes": "diced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
