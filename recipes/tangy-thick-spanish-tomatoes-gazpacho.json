{
  "title": "Tangy Thick Spanish Tomatoes Gazpacho",
  "description": "A fermented and chewy Spanish dish made with vanilla pod and cooked in a ttukbaegi earthenware pot, perfect for a weeknight dinner",
  "cuisine": "Spanish",
  "diet": [
    "paleo"
