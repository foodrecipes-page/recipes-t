  "ingredients": [
    {
      "name": "cooked rice",
      "amount": "2 cups",
      "notes": "preferably day old rice"
    },
    {
      "name": "uruguayan cheese",
      "amount": "1 cup",
      "notes": "grated"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "spring onion",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "soy sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium high heat",
    "Add the chopped onion and cook until it is translucent",
    "Add the minced garlic and cook for another minute",
    "Add the cooked rice to the skillet and stir fry for 2 minutes",
    "Add the grated uruguayan cheese to the skillet and stir until it is well combined with the rice",
    "Add the soy sauce, salt, and black pepper to the skillet and stir fry for another minute",
    "Add the chopped spring onion to the skillet and stir fry for 30 seconds",
    "Remove the skillet from the heat and serve the tangy springy uruguayan cheese fried rice hot"
  ],
