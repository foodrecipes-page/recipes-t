{
  "title": "Tender American Spring Onion Bake",
  "description": "A yeasty, glassy-jelly American dish featuring spring onions, perfect for a brunch mood, baked to perfection in a wood-fired oven, and friendly to those who avoid onion and garlic.",
  "cuisine": "American",
  "diet": [
    "vegetarian"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "spring onions",
      "amount": "1 bunch",
      "notes": "chopped"
    },
    {
      "name": "all purpose flour",
      "amount": "2 cups"
    },
    {
      "name": "active dry yeast",
      "amount": "1 teaspoon"
    },
    {
      "name": "sugar",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "unsalted butter",
      "amount": "1/4 cup",
      "notes": "melted"
    },
    {
      "name": "eggs",
      "amount": "2 large"
    },
    {
      "name": "heavy cream",
      "amount": "1 cup"
    },
    {
      "name": "shredded cheddar cheese",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Preheat the wood-fired oven to 375 degrees Fahrenheit.",
    "In a large mixing bowl, combine the flour, yeast, sugar, and salt.",
    "Add the melted butter, eggs, heavy cream, and shredded cheddar cheese to the dry ingredients and mix until a smooth batter forms.",
    "Gently fold in the chopped spring onions.",
    "Pour the batter into a greased 9x13 inch baking dish.",
    "Bake for 35 minutes or until the top is golden brown and the center is set.",
    "Remove the bake from the oven and let it cool for 10 minutes before serving.",
    "Serve warm and enjoy."
  ],
