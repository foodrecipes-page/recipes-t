      "amount": "",
      "notes": ""
    },
    {
      "name": "gruyere cheese",
      "amount": "1 cup",
      "notes": "shredded (optional)"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the oven to 375°F (190°C).",
    "In a large clay pot or oven-safe skillet, heat the olive oil over medium heat.",
    "Add the garlic and chili flakes, cooking for 1-2 minutes until fragrant.",
    "Add the thinly sliced scallions, cooking for 5-7 minutes until they begin to soften.",
    "Season with salt and black pepper to taste.",
    "Transfer the clay pot to the preheated oven and roast for 20-25 minutes, or until the scallions are tender and lightly caramelized.",
    "If using cheese, sprinkle it evenly over the scallions and continue baking for an additional 2-3 minutes, or until melted and golden brown.",
    "Garnish with chopped parsley and serve hot."
  ],
