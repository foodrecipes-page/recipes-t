  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "Smoke the binchotan charcoal for 30 minutes.",
    "Heat the olive oil in the claypot over medium heat.",
    "Add the chopped onion and cook until translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the diced beetroot, sliced carrots, and chopped celery, and cook for 10 minutes.",
    "Add the smoked binchotan charcoal, salt, and black pepper, and stir well.",
    "Cover the claypot and transfer it to the preheated oven.",
    "Bake for 1 hour and 30 minutes.",
    "Remove the claypot from the oven and stir in the chopped fresh dill."
