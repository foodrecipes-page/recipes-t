{
  "title": "Slovakian Sour Cream Pancakes",
  "description": "Tangy, crunchy Slovakian pancakes featuring semi-skimmed milk and a hint of fermented flavor.",
  "cuisine": "slovakian",
  "diet": [
    "vegetarian"
