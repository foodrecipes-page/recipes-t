      "name": "napa cabbage",
      "amount": "2 heads",
      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "pork belly",
      "amount": "1 pound",
      "notes": "cut into small pieces"
    },
    {
      "name": "ginger",
      "amount": "2 inches",
      "notes": "sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "soy sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "rice vinegar",
      "amount": "1/4 cup"
    },
    {
      "name": "sesame oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "bao buns",
      "amount": "8-10 buns"
    }
  ],
  "instructions": [
    "In a large pot, heat the sesame oil over medium heat and add the sliced ginger and cook until fragrant",
    "Add the pork belly and cook until browned on all sides",
    "Add the napa cabbage, soy sauce, and rice vinegar to the pot and stir to combine",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 20 minutes",
    "While the cabbage is cooking, steam the bao buns according to package instructions",
    "To assemble the bao, slice the cooked pork belly into thin strips and add to the steamed buns",
    "Add a spoonful of the braised napa cabbage to each bun",
    "Serve immediately and enjoy"
  ],
