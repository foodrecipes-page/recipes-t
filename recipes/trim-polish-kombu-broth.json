{
  "title": "Trim Polish Kombu Broth",
  "description": "A briny, light kombu broth with subtle umami for a quick weeknight Polish meal. Shojin-friendly and perfect for a calm dinner.",
  "cuisine": "Polish",
  "diet": [
    "vegetarian",
    "vegan"
