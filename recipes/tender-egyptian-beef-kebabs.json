    {
      "name": "Ground Beef",
      "amount": "1 pound",
      "notes": "80/20 lean to fat ratio"
    },
    {
      "name": "Kombu Cold-Extract",
      "amount": "2 tablespoons",
      "notes": "Available at most Asian markets"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "Finely chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "Minced"
    },
    {
      "name": "Paprika",
      "amount": "1 teaspoon",
      "notes": "Smoked"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon",
      "notes": "Coarse ground"
    },
    {
      "name": "Black Pepper",
      "amount": "1/2 teaspoon",
      "notes": "Freshly ground"
    },
    {
      "name": "Olive Oil",
      "amount": "2 tablespoons",
      "notes": "For brushing kebabs"
    },
    {
      "name": "Lemon Juice",
      "amount": "2 tablespoons",
      "notes": "Freshly squeezed"
    },
    {
      "name": "Fresh Cilantro",
      "amount": "1/4 cup",
      "notes": "Chopped, for garnish"
    }
  ],
  "instructions": [
    "In a large bowl, combine the ground beef, kombu cold-extract, onion, garlic, paprika, salt, and black pepper. Mix well with your hands or a wooden spoon until just combined.",
    "Cover the mixture and refrigerate for at least 30 minutes to allow the flavors to meld.",
    "Preheat a grill or grill pan to medium-high heat.",
    "Thread the beef mixture onto skewers, leaving a small space between each kebab.",
    "Brush the kebabs with olive oil and season with salt and pepper.",
    "Grill the kebabs for 8-10 minutes per side, or until cooked to your desired level of doneness.",
    "Transfer the kebabs to a plate and brush with lemon juice.",
    "Garnish with chopped cilantro and serve immediately."
  ],
