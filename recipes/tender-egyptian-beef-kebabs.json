{
  "title": "Tender Egyptian Beef Kebabs",
  "description": "A resinous, tender, and delicious Egyptian dish featuring ground beef and kombu-cold-extract, perfect for brunch.",
  "cuisine": "Egyptian",
  "diet": [
    "diabetic",
    "ketogenic"
  ],
