      "amount": "1 medium"
    },
    {
      "name": "Low-sodium soy sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "Gochujang (Korean red pepper paste)",
      "amount": "1 tablespoon"
    },
    {
      "name": "Apple cider vinegar",
      "amount": "1 tablespoon"
    },
    {
      "name": "Green onions",
      "amount": "2 pieces",
      "notes": "chopped for garnish"
    },
    {
      "name": "Lightly packed brown sugar",
      "amount": "1 teaspoon"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Wash and chop the Braeburn apples into small pieces.",
    "In a mixing bowl, combine low-sodium soy sauce, gochujang, apple cider vinegar, brown sugar, and olive oil. Mix well until sugar dissolves.",
    "Add the chopped apple pieces to the dressing and stir-fry over medium heat for about 5 minutes or until most of the liquid is absorbed.",
    "Garnish with green onions before serving."
