{
  "title": "Tasty Toasted Greek Bulgur Wheat Tiropita",
  "description": "A fresh and crisp Greek dish featuring bulgur wheat, perfect for kids, and steam cooked to perfection in a tiropita form, this recipe is gluten free friendly.",
  "cuisine": "Greek",
  "diet": [
