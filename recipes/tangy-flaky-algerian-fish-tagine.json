{
  "title": "Tangy Flaky Algerian Fish Tagine",
  "description": "A tangy and flaky Algerian dish featuring tamarind pulp, made in a papillote with fish and spices, perfect for a festive dinner.",
  "cuisine": "Algerian",
  "diet": [
    "pescatarian",
    "no onion no garlic"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "cod fish",
      "amount": "1 pound",
      "notes": "fresh and cut into 4 pieces"
    },
    {
      "name": "tamarind pulp",
      "amount": "1/2 cup",
      "notes": "mixed with 1 cup water"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "coriander",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "parchment paper",
      "amount": "1 sheet"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a small bowl, mix together the tamarind pulp and water.",
    "In another bowl, mix together the paprika, cumin, coriander, salt, and black pepper.",
    "Place the fish pieces on the parchment paper, leaving space between each piece.",
    "Brush the fish with olive oil and sprinkle with the spice mixture.",
    "Drizzle the tamarind mixture over the fish.",
    "Squeeze the lemon juice over the fish.",
    "Fold the parchment paper over the fish to create a papillote.",
    "Bake the fish for 12 minutes or until it is cooked through and flakes easily with a fork.",
    "Serve the fish hot, garnished with fresh herbs if desired."
  ],
