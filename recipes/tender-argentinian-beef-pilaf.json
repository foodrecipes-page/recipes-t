      "name": "beef strips",
      "amount": "1 pound",
      "notes": "sirloin or ribeye"
    },
    {
      "name": "cloves",
      "amount": "2 teaspoons",
      "notes": "ground"
    },
    {
      "name": "fry-grind-rice-khao-khua",
      "amount": "2 cups",
      "notes": "Thai-style fried rice"
    },
    {
      "name": "beef broth",
      "amount": "2 cups"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in the donabe vessel over medium heat.",
    "Add the beef strips and cook until browned, about 5 minutes.",
    "Add the ground cloves, salt, black pepper, and paprika, and cook for 1 minute.",
    "Add the fry-grind-rice-khao-khua and cook, stirring constantly, for 2 minutes.",
    "Add the beef broth and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 20 minutes.",
    "Fluff the pilaf with a fork and serve hot.",
    "Garnish with fresh parsley or cilantro, if desired."
  ],
