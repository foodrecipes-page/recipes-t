  "ingredients": [
    {
      "name": "White bread",
      "amount": "4 slices",
      "notes": "Gluten-free"
    },
    {
      "name": "Coconut oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Scotch bonnet peppers",
      "amount": "1/2 teaspoon",
      "notes": "Seeded and chopped"
    },
    {
      "name": "Garlic",
      "amount": "1 clove",
      "notes": "Minced"
    },
    {
      "name": "Fresh cilantro",
      "amount": "1/4 cup",
      "notes": "Chopped"
    }
  ],
  "instructions": [
    "Preheat the pressure cooker to 10 psi.",
    "In a small bowl, mix together coconut oil, salt, black pepper, scotch bonnet peppers, and garlic.",
    "Place the white bread slices in the pressure cooker and brush the mixture evenly onto each slice.",
    "Close the lid and cook for 5 minutes.",
    "Let the pressure release naturally for 2 minutes, then quick-release any remaining pressure.",
    "Open the lid and sprinkle chopped cilantro onto each slice.",
    "Serve the toasted bread hot and enjoy.",
    "Garnish with additional cilantro if desired."
  ],
