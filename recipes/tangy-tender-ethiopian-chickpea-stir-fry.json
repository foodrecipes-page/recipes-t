    },
    {
      "name": "1/2 tsp paprika"
    },
    {
      "name": "Salt and pepper to taste"
    }
  ],
  "instructions": [
    "Heat oil in a pan over medium heat.",
    "Add onion and garlic, sauté until softened.",
    "Stir in lemon juice and red wine vinegar. Reduce for about 1 minute.",
