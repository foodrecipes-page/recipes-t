    },
    {
      "name": "yuzu juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
      "name": "sesame oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "black pepper",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "edamame",
      "amount": "1 cup"
    },
    {
      "name": "mochi ice cream powder",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "In a large mixing bowl, combine glutinous rice flour and edamame.",
    "In a separate bowl, whisk together passata, yuzu juice, soy sauce, sesame oil, black pepper, and salt.",
    "Gradually pour the wet ingredients into the dry ingredients and mix until a dough forms.",
    "Knead the dough for 5 minutes until it becomes smooth and pliable.",
    "Divide the dough into small balls, about 1 inch in diameter.",
    "Shape each ball into a smooth sphere.",
    "Dip each ball into the mochi ice cream powder to coat evenly.",
    "Serve immediately and enjoy!"
  ],
