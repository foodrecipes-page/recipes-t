      "amount": "1 teaspoon"
    },
    {
      "name": "kombu",
      "amount": "1 piece",
      "notes": "dried and rinsed"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat the oil in a large pot over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the pearl barley and cook for 2 minutes, stirring constantly.",
    "Add the water, cardamom, kombu, lemon juice, and salt to the pot.",
    "Bring the mixture to a boil, then reduce the heat to low and cover the pot.",
    "Simmer the pilaf for 40 minutes, or until the barley is tender and the liquid has been absorbed.",
    "Remove the pot from the heat and let it cool for 10 minutes.",
    "Fluff the pilaf with a fork and serve hot."
  ],
