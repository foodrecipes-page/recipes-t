      "amount": "2 tablespoons"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "green onions",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "tofu",
      "amount": "1/2 cup",
      "notes": "diced"
    }
  ],
  "instructions": [
    "Heat the sesame oil in a large ttukbaegi earthenware pot over medium heat",
    "Add the minced garlic and grated ginger and cook for 1 minute",
    "Add the chicken and cook until browned on all sides",
    "Add the Korean chili flakes, icing sugar, soy sauce, and water, and stir to combine",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 20 minutes",
    "Add the diced tofu and cook for an additional 5 minutes",
    "Season with salt and pepper to taste",
    "Serve hot, garnished with chopped green onions"
  ],
