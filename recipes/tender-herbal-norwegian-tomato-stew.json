{
  "title": "Tender Herbal Norwegian Tomato Stew",
  "description": "A hearty, vegan-friendly stew featuring tender tomatoes and herbal notes, perfect for a weeknight dinner. This Norwegian-inspired dish incorporates fermented ingredients for added depth of flavor.",
  "cuisine": "Norwegian",
  "diet": [
    "vegan",
    "gluten-free"
