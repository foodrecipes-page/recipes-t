    {
      "name": "canned crushed tomatoes",
      "amount": "1 (28 oz) can",
      "notes": "preferably San Marzano"
    },
    {
      "name": "aquafaba",
      "amount": "1/2 cup",
      "notes": "liquid from canned chickpeas"
    },
    {
      "name": "Norwegian thyme",
      "amount": "2 sprigs",
      "notes": "or substitute with regular thyme"
    },
    {
      "name": "dill",
      "amount": "1/4 cup",
      "notes": "fresh, chopped"
    },
    {
      "name": "fermented sauerkraut",
      "amount": "1/4 cup",
      "notes": "drained, chopped"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat olive oil in a large pot over medium heat.",
    "Add chopped onion and sauté until translucent, about 5 minutes.",
    "Add minced garlic and cook for an additional minute, until fragrant.",
    "Add Norwegian thyme, dill, salt, and pepper. Stir to combine.",
    "Add canned crushed tomatoes, aquafaba, and fermented sauerkraut. Stir to combine.",
    "Bring the stew to a simmer and let cook for 20-25 minutes, or until the flavors have melded together and the stew has thickened slightly.",
    "Taste and adjust seasoning as needed.",
    "Serve hot, garnished with additional fresh dill if desired."
  ],
