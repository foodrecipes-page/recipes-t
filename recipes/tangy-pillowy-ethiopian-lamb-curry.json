{
  "title": "Tangy Pillowy Ethiopian Lamb Curry",
  "description": "A comforting and tangy Ethiopian dish featuring lamb, massaman paste, and tempering chocolate, served in a dolsot stone bowl.",
  "cuisine": "Ethiopian",
  "diet": [
    "low-carb"
  ],
