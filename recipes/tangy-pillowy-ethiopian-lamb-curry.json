    {
      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch pieces"
    },
    {
      "name": "massaman paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "tempering chocolate",
      "amount": "1 ounce"
    },
    {
      "name": "coconut oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "chicken broth",
      "amount": "1 cup"
    },
    {
      "name": "heavy cream",
      "amount": "1/2 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a large skillet over medium heat.",
    "Add the chopped onion and cook until it is translucent and starting to caramelize.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the lamb pieces and cook until they are browned on all sides.",
    "Add the massaman paste and cook for 1 minute, stirring constantly.",
    "Add the chicken broth, heavy cream, salt, and black pepper, and stir to combine.",
    "Bring the mixture to a simmer and cook until the lamb is tender and the sauce has thickened.",
    "Melt the tempering chocolate and stir it into the curry sauce.",
    "Taste and adjust the seasoning as needed.",
    "Serve the curry in a dolsot stone bowl."
  ],
