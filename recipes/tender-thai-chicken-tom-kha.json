{
  "title": "Tender Thai Chicken Tom Kha",
  "description": "A bitter and silky Thai dish made with panang paste and cooked in individual mini cocottes, featuring chicken and raw friendly ingredients in a tom kha form.",
  "cuisine": "Thai",
  "diet": [
    "gluten-free",
    "dairy-free"
  ],
