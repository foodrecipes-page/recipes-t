      "amount": "1/2 cup"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp"
    },
    {
      "name": "cooking oil",
      "amount": "2 tbsp"
    },
    {
      "name": "egg whites",
      "amount": "3 eggs, room temperature"
    },
    {
      "name": "unsweetened cocoa powder",
      "amount": "1/4 cup"
    },
    {
      "name": "flaxseed meal",
      "amount": "1 tbsp"
    },
    {
      "name": "coconut flour",
      "amount": "2 tbsp"
    },
    {
      "name": "almond extract",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat your air fryer to 350°F (175°C).",
    "Mix black treacle, vanilla extract, and cooking oil in a bowl.",
    "Fold egg whites into the mixture until fully incorporated. Stir in cocoa powder, flaxseed meal, coconut flour, and almond extract.",
    "Transfer half of the mixture to a lined baking dish. Spread evenly with a spatula and bake for 10 minutes or until golden brown on top.",
    "Carefully invert onto a cooling rack and let it cool completely before slicing into pieces."
  ],
