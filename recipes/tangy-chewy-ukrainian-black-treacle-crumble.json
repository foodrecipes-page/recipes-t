{
  "title": "Tangy Chewy Ukrainian Black Treacle Crumble",
  "description": "This low-carb-friendly and solo-dinner dish features a tangy black treacle filling encased in an air-fried crumb topping.",
  "cuisine": "Ukrainian",
  "diet": [
    "low-carb",
