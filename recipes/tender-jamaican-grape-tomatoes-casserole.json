{
  "title": "Tender Jamaican Grape Tomatoes Casserole",
  "description": "A nutty and gooey Jamaican dish featuring grape tomatoes in a lacquer glaze, perfect for a comforting dinner, and dairy-free friendly.",
  "cuisine": "Jamaican",
  "diet": [
    "dairy-free",
    "vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "grape tomatoes",
      "amount": "2 cups",
      "notes": "halved"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "jamaican jerk seasoning",
      "amount": "2 tablespoons"
    },
    {
      "name": "lacquer glaze",
      "amount": "1/4 cup"
    },
    {
      "name": "nutritional yeast",
      "amount": "1/4 cup"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees.",
    "In a large skillet, heat the olive oil over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "In a large bowl, whisk together the jerk seasoning, lacquer glaze, nutritional yeast, salt, and black pepper.",
    "Add the halved grape tomatoes to the bowl and toss to coat with the glaze mixture.",
    "Transfer the tomato mixture to a 9x13 inch baking dish.",
    "Bake for 25 minutes, or until the tomatoes are tender and the glaze is caramelized."
  ],
