      "amount": "",
      "notes": ""
    },
    {
      "name": "2 cups almond flour or gluten-free flour blend",
      "amount": "",
      "notes": ""
    },
    {
      "name": "1/4 cup packed light brown sugar",
      "amount": "",
      "notes": ""
    },
    {
      "name": "Pinch of salt",
      "amount": "",
      "notes": ""
    }
