{
  "title": "Tender Chaozhou Tofu Bake",
  "description": "A salty, light, romantic Chaozhou-inspired tofu bake that infuses biryani masala flavor with a simple oven bake, perfect for a vegetarian dinner.",
  "cuisine": "Chinese",
