      "name": "1 red bell pepper",
      "amount": "",
      "notes": "Chopped finely"
    },
    {
      "name": "1 yellow onion",
      "amount": "",
      "notes": "Diced"
    },
    {
      "name": "2 cloves garlic",
      "amount": "",
      "notes": "Minced"
    },
    {
      "name": "1 cup chopped spinach leaves",
      "amount": "",
      "notes": ""
    },
    {
      "name": "1/4 cup fresh parsley, finely chopped",
      "amount": "",
      "notes": ""
    },
    {
      "name": "1 tablespoon olive oil",
      "amount": ""
    },
    {
      "name": "1 tablespoon rice vinegar",
      "amount": ""
    },
    {
      "name": "1 teaspoon ground cumin",
      "amount": ""
    },
    {
      "name": "1/4 teaspoon red pepper flakes",
      "amount": ""
    },
    {
      "name": "2 cups pearl barley dumplings",
      "amount": "",
      "notes": "(Prepared ahead)"
    }
  ],
  "instructions": [
    "Heat olive oil in a wok or large skillet over medium-high heat.",
    "Add onions and cook until translucent, about 4 minutes.",
    "Add garlic and cook for an additional minute.",
    "Add bell pepper and spinach leaves to the pan. Stir-fry for 5-7 minutes until vegetables are slightly softened but still crisp-tender.",
    "Stir in rice vinegar, cumin, and red pepper flakes. Mix well and cook for another minute.",
    "Gently fold pearl barley dumplings into the stir-fry mixture and cook for an additional 2-3 minutes until dumplings are heated through.",
    "Remove from heat and garnish with chopped parsley before serving."
  ],
