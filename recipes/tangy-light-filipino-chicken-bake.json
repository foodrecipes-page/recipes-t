  "ingredients": [
    {
      "name": "boneless, skinless chicken breast",
      "amount": "1 pound",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "red chilli powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "freshly squeezed calamansi juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "onion",
      "amount": "1/2 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "tomato",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (200°C).",
    "In a large bowl, whisk together red chilli powder, salt, and black pepper.",
    "Add the chicken to the bowl and toss to coat with the spice mixture.",
    "In a separate bowl, whisk together calamansi juice and olive oil.",
    "Add the minced garlic to the bowl and mix well.",
    "Add the sliced onion and diced tomato to the bowl and toss to combine.",
    "Add the chicken to the bowl and toss to coat with the calamansi mixture.",
    "Transfer the chicken and vegetable mixture to a baking dish.",
    "Bake for 25-30 minutes or until the chicken is cooked through.",
    "Garnish with chopped cilantro and serve hot."
  ],
